S4_API_PORT=4310
S4_DB_PATH=./data/s4-agent-studio.db
AI_PROVIDER=disabled
AI_API_KEY=
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=1
AI_MAX_PROPOSAL_FILES=6
AI_MAX_OUTPUT_BYTES=120000

# Set AI_PROVIDER=nvidia and AI_API_KEY to enable NVIDIA-powered Video Director Chat.
# Leave AI_PROVIDER=disabled to use the deterministic local fallback.

OVI_ENABLED=false
OVI_BASE_URL=http://127.0.0.1:8391
OVI_API_KEY=
OVI_TIMEOUT_MS=120000

LTX_ENABLED=false
LTX_BASE_URL=http://127.0.0.1:8491
LTX_API_KEY=
LTX_TIMEOUT_MS=120000

S4_MEDIA_GENERATION_WORKER_CONCURRENCY=2
S4_MEDIA_GENERATION_POLL_INTERVAL_MS=1000
S4_MEDIA_GENERATION_MAX_PROCESSING_MS=600000
